{
  "name": "langchain-express-boot",
  "version": "1.0.0",
  "description": "基于“约定优于配置”思想，结合langchain.js框架和express.js框架打造的快速开发boot启动模板",
  "main": "dist/index.js",
  "keywords": [
    "langchain",
    "langgraph",
    "agent",
    "movie-recommendation",
    "express.js",
    "sequelize"
  ],
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon",
    "dev:prod": "cross-env NODE_ENV=production nodemon",
    "dev:test": "cross-env NODE_ENV=test nodemon",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "start:dev": "cross-env NODE_ENV=development node dist/index.js",
    "start:test": "cross-env NODE_ENV=test node dist/index.js"
  },
  "author": "Pinkman",
  "license": "ISC",
  "dependencies": {
    "@langchain/langgraph": "^1.2.2",
    "@langchain/openai": "^1.2.13",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "js-tiktoken": "^1.0.12",
    "langchain": "^1.2.34",
    "langsmith": "^0.5.0",
    "lodash": "^4.17.23",
    "moment": "^2.30.1",
    "mysql2": "^3.14.1",
    "node-sql-parser": "^5.4.0",
    "sequelize": "^6.37.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.3",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.13.10",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.9",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.1"
  }
}
